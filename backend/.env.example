# Copie para .env (dentro de backend/) para rodar a API sem Docker.
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
APP_BASE_URL=http://localhost:5173
SESSION_SECRET=dev-secret

# Opcional — só usado como seed inicial em `npm run seed`; pode deixar em
# branco e configurar depois pela tela Configurações → SSO (SAML).
SAML_ENTRY_POINT=
SAML_ISSUER=sentinela-cis
SAML_IDP_CERT=
SAML_CALLBACK_URL=

# Opcional — pasta onde os arquivos de evidência são salvos (padrão: ./uploads)
UPLOADS_DIR=
