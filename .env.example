# Copie para .env e ajuste os valores antes de subir com docker compose.
NODE_ENV=production

POSTGRES_USER=sentinela
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=sentinela
DATABASE_URL=postgresql://sentinela:troque-esta-senha@postgres:5432/sentinela

# URL pública de acesso (usada para redirecionamentos e CORS em dev)
APP_BASE_URL=https://grc.suaempresa.com.br

# Segredo de assinatura da sessão — gere um valor aleatório, ex.: openssl rand -hex 24
SESSION_SECRET=troque-este-segredo

# SAML: opcional aqui — pode deixar em branco e configurar depois pela
# própria aplicação, em Configurações → SSO (SAML). Estes valores só são
# usados uma vez, como seed inicial, na primeira execução de `npm run seed`.
SAML_ENTRY_POINT=
SAML_ISSUER=sentinela-cis
SAML_IDP_CERT=
SAML_CALLBACK_URL=https://grc.suaempresa.com.br/api/auth/saml/callback
